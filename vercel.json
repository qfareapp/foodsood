{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "privacy-policy.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/privacy-policy",
