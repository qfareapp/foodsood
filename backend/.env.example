# Local MongoDB
DATABASE_URL="mongodb://localhost:27017/foodsood"
# MongoDB Atlas (production)
# DATABASE_URL="mongodb+srv://<user>:<password>@cluster.mongodb.net/foodsood?retryWrites=true&w=majority"
PORT=3000

# Generate strong random secrets in production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me

# Optional: shorten/extend token lifetimes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=change-this-admin-password
ADMIN_PANEL_SECRET=change-this-admin-session-secret

# Firebase Admin SDK — paste the entire service account JSON as a single line
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Leave blank to disable push notifications (safe for local dev)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Brevo transactional email
# Prefer BREVO_API_KEY in production platforms like Render to avoid SMTP connection timeouts.
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=FoodSood
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_SECURE=false

# Cashfree Payments
CASHFREE_ENV=SANDBOX
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_API_VERSION=
